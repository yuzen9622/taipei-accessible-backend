PORT=5001
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000
GOOGLE_MAPS_API_KEY=
GEMINI_API_KEY=
# OpenAI-compatible base URL for the AI API (defaults to Gemini's OpenAI-compat endpoint)
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/openai
# Model name for all AI features including agent chat
GEMINI_MODEL=gemini-2.5-flash
# JWT Secret
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
# Mongodb Database 
DATABASE_URL=
TDX_CLIENT_ID=
TDX_CLIENT_SECRET=
ORS_API_KEY=
# Set to "true" to fill OTP coverage gaps (TRA, intercity) via TDX hosted routing API
USE_TDX_ROUTING=false
# Phase 16 OTP2 sidecar rollout: "false" | "shadow" (run + log diff only) | "true" (merge)
USE_OTP_ROUTER=false
# OTP2 GraphQL server base URL (internal network only)
OTP_BASE_URL=http://localhost:8080
