NODE_ENV=development
CORS_ORIGINS=http://localhost:3000
GOOGLE_MAPS_API_KEY=
# Self-hosted Valhalla — drive / motorcycle / walk route planning
VALHALLA_BASE_URL=http://localhost:8002
VALHALLA_DATA_DIR=./valhalla-data
VALHALLA_PBF_PATH=./otp-data/taiwan-latest.osm.pbf
VALHALLA_THREADS=2
GEMINI_API_KEY=
# OpenAI-compatible base URL for the AI API (defaults to Gemini's OpenAI-compat endpoint)
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/openai
# Model name for all AI features including agent chat
GEMINI_MODEL=gemini-3-flash-preview
# JWT Secret
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
# Mongodb Database
DATABASE_URL=
# Redis — LINE conversation state (pending intent, chat history) and route caches.
# Optional: unset degrades gracefully, but multi-turn LINE slot-filling needs it.
REDIS_URL=redis://localhost:6379
TDX_CLIENT_ID=
TDX_CLIENT_SECRET=
# OTP2 GraphQL server base URL (internal network only). OTP is the only route planner.
OTP_BASE_URL=http://localhost:8080
# --- Hazard Report ---
# GCS bucket for hazard-report photos (required to submit reports)
GCS_BUCKET_NAME=
# GCS / Cloud Vision service-account JSON key path (omit to use Workload Identity / ADC)
GCS_KEY_FILE=
# Photo upload size cap (MB)
HAZARD_PHOTO_MAX_SIZE_MB=10
# Set to "false" to skip the whole AI image check (verdict stays "skipped")
USE_HAZARD_AI_VERIFY=true
# Set to "false" to skip the Cloud Vision prefilter and go straight to Gemini
USE_VISION_PREFILTER=true
# --- Pre-Trip Environment ---
# CWA open-data API key for weather (required for the /a11y/environment weather block)
CWA_API_KEY=
CHROMA_URL=http://localhost:8100
# Optional but recommended in production: encrypts UserMemory.content at rest.
MEMORY_ENCRYPTION_KEY=
# --- SOS / LINE ---
# LINE Messaging API channel access token (long-lived); used by line.adapter.ts
LINE_CHANNEL_ACCESS_TOKEN=
# LINE channel secret for webhook HMAC-SHA256 signature verification
LINE_CHANNEL_SECRET=
# Official account basic id (e.g. @xxxxxxx) used to build the add-friend bind URL
LINE_BOT_BASIC_ID=
# Public tracking page domain (frontend, not the backend API), e.g. https://app.example.com
PUBLIC_TRACKING_BASE_URL=
# Optional LIFF route preview URL, e.g. https://liff.line.me/123456-route
PUBLIC_LIFF_ROUTE_BASE_URL=
# --- Voice POC (Phase 0, Gemini Live API) ---
# Gemini Live API model for the real-time voice bridge
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
# Voice Live sampling temperature (optional; default 0 = matches text agent; valid range 0-2)
GEMINI_LIVE_TEMPERATURE=
# Voice Live output-synthesis language code (optional; unset = omit; verify against Gemini Live supported languages before enabling, e.g. cmn-TW)
GEMINI_LIVE_LANGUAGE_CODE=
# Mount the browser POC test page at /api/v1/voice/poc (leave false outside local POC)
VOICE_POC_ENABLED=false
# Emit full unbounded tool traces to server logs (local debug only, never in deployment)
VOICE_POC_TRACE=false
