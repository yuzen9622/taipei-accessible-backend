# Keep the build context small + secrets out of the image.
node_modules
dist
.git
.gitignore
# Large data dirs — never needed inside the API image (built/served elsewhere)
otp-data
data
*.osm.pbf
*.gtfs.zip
# Secrets — injected at runtime via compose env_file, never baked in
.env
.env.*
!.env.example
# Misc
*.log
npm-debug.log*
.DS_Store
docs
*.md
