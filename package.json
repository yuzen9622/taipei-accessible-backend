{
    "name": "taipei-accessible-backend",
    "version": "1.0.0",
    "description": "Backend server for Taipei Accessible project",
    "main": "dist/server.js",
    "scripts": {
        "build": "tsc",
        "start": "node dist/server.js",
        "dev": " dotenvx run -- nodemon",
        "clean": "rimraf dist",
        "lint:arch": "node scripts/check-architecture.mjs",
        "test": "vitest run",
        "test:watch": "vitest",
        "prebuild": "npm run clean",
        "postinstall": "npm run build",
        "import:osm": "npx dotenvx run -- ts-node src/scripts/import-osm-a11y.ts",
        "import:tdx-stops": "npx dotenvx run -- ts-node src/scripts/import-tdx-stops.ts",
        "import:tdx-bus-routes": "npx dotenvx run -- ts-node src/scripts/import-tdx-bus-routes.ts",
        "import:tdx-bus-vehicles": "npx dotenvx run -- ts-node src/scripts/import-tdx-bus-vehicles.ts",
        "import:tdx-metro": "npx dotenvx run -- ts-node src/scripts/import-tdx-metro.ts",
        "import:tdx-thsr": "npx dotenvx run -- ts-node src/scripts/import-tdx-thsr.ts",
        "import:tdx-tra": "npx dotenvx run -- ts-node src/scripts/import-tdx-tra.ts",
        "import:gtfs-stops": "npx dotenvx run -- ts-node src/scripts/import-gtfs-stops.ts",
        "import:gtfs-trips": "npx dotenvx run -- ts-node src/scripts/import-gtfs-trips.ts",
        "import:gtfs-pathways": "npx dotenvx run -- ts-node src/scripts/import-gtfs-pathways.ts",
        "import:gtfs-levels": "npx dotenvx run -- ts-node src/scripts/import-gtfs-levels.ts",
        "generate:gtfs-parents": "npx dotenvx run -- ts-node src/scripts/generate-gtfs-parents.ts",
        "build:otp": "npm run generate:gtfs-parents && docker-compose run --rm otp --build --save",
        "import:gtfs-all": "npx dotenvx run -- node --max-old-space-size=2048 -r ts-node/register src/scripts/import-gtfs-all.ts",
        "import:bathrooms": "npx dotenvx run -- ts-node src/scripts/import-bathrooms.ts",
        "import:parking": "npx dotenvx run -- ts-node src/scripts/import-disabled-parking.ts",
        "import:welfare": "npx dotenvx run -- ts-node src/scripts/import-welfare.ts",
        "import:campus-a11y": "npx dotenvx run -- ts-node src/scripts/import-campus-a11y.ts",
        "backfill:campus-search": "npx dotenvx run -- ts-node src/scripts/backfill-campus-search.ts",
        "import:campus-facility-detail": "npx dotenvx run -- ts-node src/scripts/import-campus-facility-detail.ts",
        "hazard:expire": "npx dotenvx run -- ts-node src/scripts/expire-hazard-reports.ts",
        "import:knowledge": "npx dotenvx run -- ts-node src/scripts/import-knowledge.ts",
        "import:taichung-disability-rag": "npx dotenvx run -- ts-node src/scripts/import-taichung-disability-rag.ts",
        "import:visual-a11y": "npx dotenvx run -- ts-node src/scripts/import-visual-a11y.ts",
        "eval:routing": "npx dotenvx run -- ts-node src/scripts/eval-tool-routing.ts"
    },
    "keywords": [
        "express",
        "typescript",
        "backend",
        "taipei",
        "accessible"
    ],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@asteasolutions/zod-to-openapi": "^8.5.0",
        "@dotenvx/dotenvx": "^1.50.1",
        "@google-cloud/storage": "^7.21.0",
        "@google-cloud/vision": "^5.3.7",
        "@google/genai": "^1.22.0",
        "@googlemaps/google-maps-services-js": "^3.4.2",
        "@googlemaps/polyline-codec": "^1.0.28",
        "@line/bot-sdk": "^11.2.0",
        "@scalar/express-api-reference": "^0.9.20",
        "axios": "^1.17.0",
        "bcryptjs": "^3.0.2",
        "chromadb": "^3.4.3",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "exifr": "^7.1.3",
        "express": "^4.18.2",
        "express-rate-limit": "^8.5.2",
        "helmet": "^7.0.0",
        "ioredis": "^5.11.1",
        "jsonwebtoken": "^9.0.2",
        "mime": "^4.1.0",
        "mongoose": "^8.18.1",
        "morgan": "^1.10.0",
        "multer": "^2.2.0",
        "openai": "^6.42.0",
        "proj4": "^2.20.9",
        "rate-limit-redis": "^5.0.0",
        "rimraf": "^6.0.1",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@types/cookie-parser": "^1.4.9",
        "@types/cors": "^2.8.13",
        "@types/express": "^4.17.17",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/morgan": "^1.9.4",
        "@types/multer": "^2.1.0",
        "@types/node": "^20.19.19",
        "@types/proj4": "^2.5.6",
        "@types/supertest": "^7.2.0",
        "nodemon": "^3.0.1",
        "supertest": "^7.2.2",
        "ts-node": "^10.9.1",
        "typescript": "^5.1.6",
        "vitest": "^4.1.9"
    }
}
